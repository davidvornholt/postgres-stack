# Host bind addresses. Keep localhost for single-machine setups.
POSTGRES_PROD_BIND_HOST=127.0.0.1
POSTGRES_DEV_BIND_HOST=127.0.0.1

# Published host ports.
POSTGRES_PROD_PORT=5423
POSTGRES_DEV_PORT=5433

# Per-instance database users.
POSTGRES_PROD_USER=postgres
POSTGRES_DEV_USER=postgres

# Change these before exposing the stack beyond localhost.
POSTGRES_PROD_PASSWORD=change-me-prod
POSTGRES_DEV_PASSWORD=change-me-dev
